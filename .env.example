# =============================================================
#  LogisticaBroker — Plantilla de variables de entorno
#  Copiar este archivo como ".env" y completar los valores reales.
#  Este archivo SÍ se versiona; ".env" NO.
# =============================================================

# --- Base de Datos (PostgreSQL) ---
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=LogisticaBrokerDb;Username=USUARIO;Password=CONTRASEÑA

# --- Servicio de Correo (SMTP) ---
# Para Gmail usar una "Contraseña de aplicación" (App Password)
MailSettings__Mail=tu_correo@gmail.com
MailSettings__DisplayName=Nombre Visible
MailSettings__Password=xxxx_xxxx_xxxx_xxxx
MailSettings__Host=smtp.gmail.com
MailSettings__Port=587

# --- ASP.NET Core ---
# Development | Staging | Production
ASPNETCORE_ENVIRONMENT=Development
